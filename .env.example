# ── 模型选择 ──
# openrouter = OpenRouter 聚合模型
# zhipu = 智谱 GLM
# volcengine = 火山引擎 DeepSeek
# deepseek = DeepSeek 直连
ACTIVE_MODEL=openrouter

# ── OpenRouter 配置 (ACTIVE_MODEL=openrouter) ──
OPENROUTER_API_KEY=你的OpenRouter密钥
OPENROUTER_MODEL=你要使用的OpenRouter模型名
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# 可选：用于 OpenRouter 排名与来源标识
# OPENROUTER_SITE_URL=https://your-site.example
# OPENROUTER_APP_NAME=fin_robot

# ── 智谱 GLM 配置 (ACTIVE_MODEL=zhipu) ──
ZHIPU_API_KEY=你的智谱API密钥
ZHIPU_MODEL=glm-4.5-air
ZHIPU_VISION_MODEL=glm-4.6v-flash
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ── 火山引擎配置 (ACTIVE_MODEL=volcengine) ──
VOLCENGINE_API_KEY=你的火山引擎密钥
VOLCENGINE_ENDPOINT_ID=你的端点ID
# VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── DeepSeek 直连配置 (ACTIVE_MODEL=deepseek) ──
DEEPSEEK_API_KEY=你的DeepSeek密钥
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── Telegram 配置 ──
TELEGRAM_BOT_TOKEN=你的Telegram机器人Token

# ── RSS 抓取配置 ──
# 不配置时将使用内置默认源
RSS_FEEDS_JSON=[{"name":"36kr","url":"https://36kr.com/feed"},{"name":"tmtpost","url":"https://www.tmtpost.com/rss.xml"},{"name":"bbc_business","url":"https://feeds.bbci.co.uk/news/business/rss.xml"},{"name":"cnbc_finance","url":"https://www.cnbc.com/id/100003114/device/rss/rss.html"},{"name":"wsj_markets","url":"https://feeds.a.dj.com/rss/RSSMarketsMain.xml"},{"name":"marketwatch_top","url":"https://feeds.marketwatch.com/marketwatch/topstories/"},{"name":"techcrunch","url":"https://techcrunch.com/feed/"}]
SQLITE_DB_PATH=fin_robot.db

# ── X/Twitter 博主追踪（量化情感因子） ──
# JSON 数组，每个元素包含 user(用户名), weight(权重0~1), tags(标签数组), note(备注)
# 权重用于后续量子化因子的情感加权总和
X_TRACKED_USERS=[{"user":"elonmusk","weight":0.3,"tags":["科技","宏观"],"note":"马斯克"},{"user":"CathieDWood","weight":0.2,"tags":["ARK","创新"],"note":"木头姐"}]

# X 登录凭据（从浏览器开发者工具 Cookies 中获取 auth_token）
# 参考: https://x.com → F12 → Application → Cookies → x.com → auth_token
X_AUTH_TOKEN=你的auth_token

# ── 信息源分类配置 ──
# 每个 source 必须属于: macro / market / industry / sentiment / policy
# 不配置时使用内置默认映射，此处可覆盖
# SOURCE_PROFILES_JSON={"Reuters":"macro","elonmusk":"industry"}
